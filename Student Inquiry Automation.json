        "message": "=<div style=\"margin:0;padding:0;background:#f2f4f7;\">\n<table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n<tr>\n<td align=\"center\" style=\"padding:12px;\">\n\n<table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" style=\"max-width:420px;background:#ffffff;border-radius:12px;font-family:Arial,Helvetica,sans-serif;overflow:hidden;\">\n\n<tr>\n<td align=\"center\" style=\"background:#198754;padding:18px;\">\n<img src=\"https://tgcdehradun.com/wp-content/uploads/2025/01/tgc-logo.png\" width=\"95\" alt=\"TGC Logo\">\n<h2 style=\"color:#ffffff;margin:8px 0 0 0;font-size:18px;\">Welcome to TGC Institute</h2>\n</td>\n</tr>\n\n<tr>\n<td style=\"padding:18px;color:#333;font-size:14px;line-height:1.6;\">\n\n<p style=\"margin-top:0;\">Hi <strong>{{ $json['User Message'].match(/name\\s+([a-zA-Z]+)/i)?.[1] || 'Student' }}</strong>,</p>\n\n<p>Thank you for your strong interest in the <strong>{{ $json['User Message'].match(/[a-zA-Z]+\\s+course/i)?.[0] || 'program' }}</strong>.<br>\nWe would be happy to assist you with the admission process and help you get started.</p>\n\n<p>Our academic counselor can schedule a quick call or demo session at your convenient time.<br>\nPlease let us know a suitable time so we can proceed further.</p>\n\n<p>Looking forward to helping you begin your learning journey.</p>\n\n<p>Regards,<br>\n<strong>Admissions Team</strong><br>\nTGC Institute</p>\n\n</td>\n</tr>\n\n<tr>\n<td align=\"center\" style=\"background:#f1f3f5;padding:10px;font-size:11px;color:#888;\">\nTGC Institute\n</td>\n</tr>\n\n</table>\n\n</td>\n</tr>\n</table>\n</div>",
