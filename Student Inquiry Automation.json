    {
      "parameters": {
        "jsCode": "// Grab the \"User Message\" field and turn the whole conversation into a lowercase string\nlet query = JSON.stringify($json[\"User Message\"] || \"\").toLowerCase();\n\n// Start the score at 0\nlet score = 0;\n\n// Add points ONLY if these specific words are found\nif(query.includes(\"python\") || query.includes(\"course\")){\n  score += 10;\n}\n\nif(query.includes(\"name\") || query.includes(\"start\")){\n  score += 15;\n}\n\nif(query.includes(\"email\")){\n  score += 20;\n}\n\nif(query.includes(\"phone\") || query.includes(\"admission\")){\n  score += 40;\n}\n\n// Output the final calculated score\nreturn [\n  {\n    json:{\n      ...$json,\n      Score: score\n    }\n  }\n];"
      },
