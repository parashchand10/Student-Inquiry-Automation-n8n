      "parameters": {
        "jsCode": "return [\n{\njson:{\nEmail: $json.Email,\nsubject: \"Thanks for your interest in \" + $json.Course_name,\nmessage: `\n\n<!-- Header --> \n<div style=\"background:#0b5ed7;padding:20px;text-align:center;\"> \n<img src=\"https://tgcdehradun.com/wp-content/uploads/2025/01/tgc-logo.png\" style=\"height:60px;\"> \n</div> \n\n<!-- Body --> \n<div style=\"padding:30px;color:#333;\"> \n\n<h2 style=\"margin-top:0;\">Hi ${$json.Name}</h2> \n\n<p style=\"font-size:16px;line-height:1.6;\">\nThank you for sharing your details. We’re excited that you're interested in the \n<b style=\"color:#0b5ed7;\">${$json.Course_name} Course</b>.\n</p> \n\n<p style=\"font-size:16px;line-height:1.6;\">\nOur academic counselor will contact you shortly via <b>call or email</b> to guide you through admission process, course structure, fees and career opportunities.\n</p> \n\n<div style=\"text-align:center;margin:30px 0;\"> \n<a href=\"https://tgcdehradun.com\" style=\"background:#0b5ed7;color:white;padding:14px 28px;text-decoration:none;border-radius:6px;font-weight:bold;display:inline-block;\">\nExplore More Courses\n</a> \n</div> \n\n<p style=\"font-size:15px;color:#555;\">\nIf you have any questions, feel free to reply to this email. We are always happy to help.\n</p> \n\n<p style=\"margin-top:30px;\">\nRegards,<br>\n<b>Admissions Team</b><br>\nTGC Institute\n</p> \n\n</div> \n\n<div style=\"background:#f1f3f5;padding:15px;text-align:center;font-size:13px;color:#777;\">\n© 2025 TGC Institute | All Rights Reserved\n</div>\n\n`\n}\n},\n\n{\njson:{\nEmail: \"parashchand01@gmail.com\",\nsubject: \"New Student Lead\",\nmessage: `\n\n<div style=\"margin:0;padding:0;background:#f2f4f7;\">\n<table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n<tr>\n<td align=\"center\" style=\"padding:12px;\">\n\n<table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\" style=\"max-width:420px;background:#ffffff;border-radius:12px;font-family:Arial,Helvetica,sans-serif;overflow:hidden;\">\n\n<tr>\n<td align=\"center\" style=\"background:#198754;padding:18px;\">\n<img src=\"https://tgcdehradun.com/wp-content/uploads/2025/01/tgc-logo.png\" width=\"95\">\n<h2 style=\"color:#ffffff;margin:8px 0 0 0;font-size:18px;\">New Student Lead</h2>\n</td>\n</tr>\n\n<tr>\n<td style=\"padding:18px;color:#333;font-size:14px;line-height:1.6;\">\n\n<p style=\"margin-top:0;\">Hello Team</p>\n\n<p>\nA new student has shown interest in joining a course. Please connect with the student quickly.\n</p>\n\n<table width=\"100%\" style=\"background:#f7f7f7;border-radius:8px;padding:14px;margin-top:10px;\">\n<tr><td style=\"padding:6px 0;\"><strong>Name:</strong> ${$json.Name}</td></tr>\n<tr><td style=\"padding:6px 0;\"><strong>Email:</strong> ${$json.Email}</td></tr>\n<tr><td style=\"padding:6px 0;\"><strong>Phone:</strong> ${$json.Phone}</td></tr>\n<tr><td style=\"padding:6px 0;\"><strong>Course:</strong> <span style=\"color:#198754;font-weight:bold;\">${$json.Course_name}</span></td></tr>\n<tr><td style=\"padding:6px 0;\"><strong>Inquiry Time:</strong> ${$json.Timing}</td></tr>\n</table>\n\n<table width=\"100%\" style=\"margin-top:16px;\">\n<tr>\n<td>\n<a href=\"tel:${$json.Phone}\" style=\"background:#198754;color:#fff;text-decoration:none;display:block;text-align:center;padding:13px;border-radius:6px;font-weight:bold;font-size:14px;\">\nCall Student\n</a>\n</td>\n</tr>\n</table>\n\n<table width=\"100%\" style=\"margin-top:10px;\">\n<tr>\n<td>\n<a href=\"mailto:${$json.Email}\" style=\"background:#0d6efd;color:#fff;text-decoration:none;display:block;text-align:center;padding:13px;border-radius:6px;font-weight:bold;font-size:14px;\">\nSend Email\n</a>\n</td>\n</tr>\n</table>\n\n<p style=\"font-size:12px;color:#777;margin-top:16px;\">\nFast follow-up improves admission conversion\n</p>\n\n</td>\n</tr>\n\n<tr>\n<td align=\"center\" style=\"background:#f1f3f5;padding:10px;font-size:11px;color:#888;\">\nTGC Institute\n</td>\n</tr>\n\n</table>\n\n</td>\n</tr>\n</table>\n</div>\n\n`\n}\n}\n];"
